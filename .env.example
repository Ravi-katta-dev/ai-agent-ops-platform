# AI Agent Ops Platform - Environment Configuration
# Copy this file to .env and update with your actual values

# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Claude AI Configuration (Anthropic)
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# Composio Platform Configuration
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_WEBHOOK_SECRET=your_webhook_secret_here

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/ai_agent_ops
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai_agent_ops
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_SSL=false

# Redis Configuration (Caching & Sessions)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Authentication
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FORMAT=combined

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=25000
WS_HEARTBEAT_TIMEOUT=60000

# Agent Configuration
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_MS=300000
AGENT_RESPONSE_TIMEOUT=30000

# Tool Integration Settings
TOOL_RETRY_ATTEMPTS=3
TOOL_TIMEOUT_MS=30000
WEBHOOK_TIMEOUT_MS=10000

# Security
CORS_ORIGIN=http://localhost:3000
SESSION_SECRET=your_session_secret_here

# Monitoring & Analytics
SENTRY_DSN=your_sentry_dsn_here
ANALYTICS_ENABLED=false

# Feature Flags
FEATURE_AGENT_DEVOPS=true
FEATURE_AGENT_DATA_ANALYST=true
FEATURE_AGENT_CUSTOMER_SUPPORT=true
FEATURE_AGENT_MARKETING=true
FEATURE_AGENT_SECURITY=true
FEATURE_AGENT_AI_COORDINATOR=true