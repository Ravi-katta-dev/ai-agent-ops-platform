# Server Configuration
NODE_ENV=development
PORT=3001
HOST=localhost

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ai_agent_ops
REDIS_URL=redis://localhost:6379

# Claude AI Configuration
CLAUDE_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4096
CLAUDE_TEMPERATURE=0.7

# Composio Configuration
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_BASE_URL=https://backend.composio.dev/api
COMPOSIO_WEBHOOK_SECRET=your_webhook_secret_here

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET=your_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# WebSocket
SOCKET_IO_CORS_ORIGINS=http://localhost:3000

# Agent Configuration
MAX_CONCURRENT_AGENTS=6
AGENT_TIMEOUT_MS=300000
AGENT_RETRY_ATTEMPTS=3

# Tool Integration Limits
MAX_TOOLS_PER_AGENT=10
TOOL_EXECUTION_TIMEOUT=60000

# File Upload (if needed)
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# Monitoring & Health Checks
HEALTH_CHECK_INTERVAL=30000
METRICS_PORT=9090