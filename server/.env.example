# Server Configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h

# Claude AI Configuration
CLAUDE_API_KEY=sk-ant-api03-your-claude-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=4000

# Composio Configuration
COMPOSIO_API_KEY=your-composio-api-key-here
COMPOSIO_BASE_URL=https://backend.composio.dev
COMPOSIO_ENTITY_ID=default

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/ai_agent_ops_db
DATABASE_SSL=false
DATABASE_POOL_SIZE=20

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Agent Configuration
MAX_CONCURRENT_AGENTS=6
AGENT_TIMEOUT_MS=30000
TASK_RETRY_ATTEMPTS=3

# Tool Integration Limits
MAX_TOOL_CONNECTIONS=50
TOOL_TIMEOUT_MS=10000
WEBHOOK_RETRY_ATTEMPTS=3

# Security
ENCRYPTION_KEY=your-32-character-encryption-key-here
CORS_ORIGIN=http://localhost:3000
API_VERSION=v1